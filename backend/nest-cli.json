{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "templates/**/*", "outDir": "dist" },
      { "include": "templates/**/*.txt", "outDir": "dist" },
      { "include": "templates/**/*.html", "outDir": "dist" },
      "**/*.html",
      "**/*.txt"
    ],
    "watchAssets": true
  }
}